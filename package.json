{
  "name": "phantombot",
  "version": "0.1.0",
  "description": "Giving the harness a Soul. The harness can do its own tools — let it. Personality-first chat agent CLI on Bun.",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "phantombot": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "gen:pi-extension": "bun scripts/genPiExtensionAssets.ts",
    "build": "bun run build:x64",
    "build:x64": "mkdir -p dist && bun build --compile --target=bun-linux-x64-baseline ./src/index.ts --outfile dist/phantombot",
    "build:arm64": "mkdir -p dist && bun build --compile --target=bun-linux-arm64 ./src/index.ts --outfile dist/phantombot-arm64"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "citty": "^0.1.6",
    "cron-parser": "^5.5.0",
    "nostr-tools": "2.23.3",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
